---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, CLOUDFLARE_ANALYTICS_TOKEN } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Apply the saved accent theme before paint (no flash).
      (function () {
        try {
          var t = localStorage.getItem('allocate-theme') || 'rosepine-dawn';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'rosepine-dawn');
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}/brand/favicon-32.png`} type="image/png" sizes="32x32" />
    <link rel="icon" href={`${base}/brand/icon-192.png`} type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href={`${base}/brand/apple-touch-icon.png`} />

    <!-- Self-hosted serif display face (Fraunces) -->
    <link rel="preload" href={`${base}/fonts/fraunces-2.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href={`${base}/fonts/fraunces.css`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(`${base}/brand/og-image.png`, Astro.site).href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(`${base}/brand/og-image.png`, Astro.site).href} />

    <!--
      Cloudflare Web Analytics (cookieless, privacy-first).
      Set CLOUDFLARE_ANALYTICS_TOKEN in src/config.ts to enable.

      Self-exclusion: visit any page with ?analytics=off once per
      browser/device to stop the beacon loading there (persisted in
      localStorage). Use ?analytics=on to re-enable.
    -->
    {
      CLOUDFLARE_ANALYTICS_TOKEN && (
        <script is:inline define:vars={{ token: CLOUDFLARE_ANALYTICS_TOKEN }}>
          (function () {
            try {
              var p = new URLSearchParams(location.search).get('analytics');
              if (p === 'off') localStorage.setItem('cf-analytics-opt-out', '1');
              if (p === 'on') localStorage.removeItem('cf-analytics-opt-out');
              if (localStorage.getItem('cf-analytics-opt-out') === '1') {
                console.info('[analytics] disabled on this device');
                return;
              }
            } catch (e) {
              /* localStorage unavailable — fall through and load beacon */
            }
            var s = document.createElement('script');
            s.defer = true;
            s.src = 'https://static.cloudflareinsights.com/beacon.min.js';
            s.setAttribute('data-cf-beacon', JSON.stringify({ token: token }));
            document.head.appendChild(s);
          })();
        </script>
      )
    }
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
