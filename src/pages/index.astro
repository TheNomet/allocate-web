---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Feature from '../components/Feature.astro';
import FeatureRow from '../components/FeatureRow.astro';
import { icons } from '../components/icons';
import { SITE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const defaultTheme = 'rosepine-dawn';

const secondary = [
  {
    icon: icons.calendar,
    title: 'Calm',
    body: 'Check in once a month — no real-time pings, no daily guilt. See where you landed, adjust, and get on with your life.',
  },
  {
    icon: icons.lock,
    title: 'Private',
    body: 'No account, no backend, no bank login. Everything stays on your Mac and your own iCloud — there’s nothing for anyone to sell or leak.',
  },
  {
    icon: icons.tag,
    title: 'Free',
    body: 'No subscription, no paid bank connectors. You shouldn’t have to pay money just to understand your money.',
  },
];

// Theme presets that mirror the app's Appearance settings. Clicking a swatch
// re-themes this site live (handled by the data-set-theme listener in Header).
const themes = [
  { id: 'rosepine-dawn', name: 'Rosé Pine Dawn', bg: '#faf4ed', accent: '#907aa9', text: '#575279' },
  { id: 'rosepine', name: 'Rosé Pine', bg: '#191724', accent: '#c4a7e7', text: '#e0def4' },
  { id: 'nord', name: 'Nord', bg: '#2e3440', accent: '#88c0d0', text: '#eceff4' },
  { id: 'catppuccin', name: 'Catppuccin', bg: '#1e1e2e', accent: '#cba6f7', text: '#cdd6f4' },
  { id: 'tokyonight', name: 'Tokyo Night', bg: '#1a1b26', accent: '#7aa2f7', text: '#c0caf5' },
  { id: 'gruvbox', name: 'Gruvbox', bg: '#282828', accent: '#fabd2f', text: '#ebdbb2' },
];

const setupSteps = [
  {
    n: '1',
    title: 'Set your goal',
    body: 'Decide how much to pay yourself each month — the amount you’ll save and invest before spending on anything else.',
  },
  {
    n: '2',
    title: 'Build your budgets',
    body: 'Turn that goal into budgets for the rest. Allocate suggests budgets from your past spending, so the targets are grounded in reality, not wishful thinking.',
  },
];

const monthlySteps = [
  {
    n: '1',
    title: 'Import your statement',
    body: 'Export a PDF, CSV, or Excel file from your bank and drop it into Allocate. No bank connection, no extra fees.',
  },
  {
    n: '2',
    title: 'Let the AI sort it',
    body: 'Every transaction is categorized automatically — on your Mac. Skim it, fix the few it wasn’t sure about, and you’re done in minutes.',
  },
  {
    n: '3',
    title: 'See where you landed',
    body: 'Did you pay yourself first? Are you over or under budget? Is your net worth climbing? Allocate shows you clearly.',
  },
  {
    n: '4',
    title: 'Adjust, then live',
    body: 'Nudge next month’s plan to keep a good average over the long run. Then close the laptop and get on with your life.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container container--wide hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">macOS personal finance</p>
        <h1>Pay yourself<br />first.</h1>
        <p class="lead">
          Allocate turns a bank statement into a clear picture of what you earned,
          what you kept, and whether you’re on track — automatically, and entirely
          on your Mac.
        </p>
        <div class="hero__cta">
          <Button href="/download">Get Allocate</Button>
          <Button href="/#how" variant="secondary">See how it works</Button>
        </div>
        <p class="hero__note text-muted">
          {SITE.requirements} · No account · Free
        </p>
      </div>
      <div class="hero__media">
        <figure class="shot shot--hero">
          <div class="shot__body">
            <video
              data-demo
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster={`${base}/screenshots/${defaultTheme}/home.png`}
              aria-label="Screen recording touring Allocate's dashboard, budget, goals, and net worth"
            >
              <source data-demo-src="webm" src={`${base}/demo-${defaultTheme}.webm`} type="video/webm" />
              <source data-demo-src="mp4" src={`${base}/demo-${defaultTheme}.mp4`} type="video/mp4" />
            </video>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- Intro / what is Allocate -->
  <section class="section--tight intro">
    <div class="container center">
      <p class="eyebrow">Your money, in one calm view</p>
      <h2 class="intro__headline">
        Accounts, budgets, goals, and net worth — together, and entirely yours.
      </h2>
      <p class="lead intro__lead">
        Import a statement, let the AI sort it, and see exactly where you stand.
        No sign-up, no subscription, and nothing leaves your Mac.
      </p>
      <ul class="intro__chips">
        <li>On-device storage</li>
        <li>iCloud sync</li>
        <li>No account</li>
        <li>AI runs on your Mac</li>
      </ul>
    </div>
  </section>

  <!-- Feature rows -->
  <section id="features" class="section">
    <div class="container feature-rows">
      <div class="frow">
        <div class="frow__copy">
          <p class="eyebrow">The headline number</p>
          <h3 class="frow__title">Pay yourself first</h3>
          <p class="frow__body text-muted">
            Decide what you set aside before anything else — like a salary you owe
            your future self. Allocate shows the one number that matters: how much
            of your income you actually kept, saved, and invested.
          </p>
          <ul class="frow__list">
            <li>Saved vs. invested at a glance</li>
            <li>Month, quarter, or year</li>
            <li>On-track banner against your annual target</li>
          </ul>
        </div>
        <div class="frow__media">
          <figure class="shot pyf" aria-label="Pay Yourself First rate of 26%, on track against a 20% annual target">
            <div class="pyf__head">
              <span class="pyf__eyebrow">Pay Yourself First</span>
              <span class="pyf__pill">On track</span>
            </div>
            <div class="pyf__rate">
              <strong>26<span>%</span></strong>
              <span class="pyf__rate-label">of income kept, saved &amp; invested this month</span>
            </div>
            <div class="pyf__bar" role="img" aria-label="26 percent versus a 20 percent target">
              <span class="pyf__bar-fill" style="width:26%"></span>
              <span class="pyf__bar-target" style="left:20%"><i></i>20% target</span>
            </div>
            <div class="pyf__split">
              <div class="pyf__stat">
                <span class="pyf__dot pyf__dot--saved"></span>
                <span class="pyf__stat-k">Saved</span>
                <b>kr 0</b>
              </div>
              <div class="pyf__stat">
                <span class="pyf__dot pyf__dot--invested"></span>
                <span class="pyf__stat-k">Invested</span>
                <b>kr 16 000</b>
              </div>
            </div>
            <p class="pyf__foot">You set aside <b>kr 16 000</b> of kr 61 000 income.</p>
          </figure>
        </div>
      </div>

      <FeatureRow
        eyebrow="New in v1"
        title="See your net worth grow"
        name="net-worth"
        alt="Net Worth page with a history trend chart and per-account breakdown"
        flip
        bullets={['Every account in one figure', 'History trend over time', 'Credit cards counted as liabilities']}
      >
        Watch the number that compounds. Net Worth pulls every account together —
        checking, savings, investments, even credit cards — and charts how your
        contributions add up over time. Real money in, not market guesswork.
      </FeatureRow>

      <FeatureRow
        eyebrow="Goals → budgets"
        title="Budgets grounded in reality"
        name="budget"
        alt="Budget matrix with categories across months"
        bullets={['Suggested from your own history', 'A year-at-a-glance matrix', 'Recalculate from actuals anytime']}
      >
        Pick how much to save and invest, then let the rest become budgets.
        Allocate suggests targets from your past spending and lays the whole year
        out in one matrix — so you can see, month by month, where you’re over or
        under.
      </FeatureRow>

      <FeatureRow
        eyebrow="Stay on track"
        title="Set goals, then crush them"
        name="goals"
        alt="Goals page showing progress toward savings targets"
        flip
        bullets={['Now vs. goal vs. monthly needed', 'Apply a goal to your budget in one step', 'Flags when your plan falls short']}
      >
        Save for a home deposit, a trip, or a rainy-day fund. Allocate tracks how
        far you’ve come, what’s left, and how much to set aside each month — and
        can write that straight into your budget.
      </FeatureRow>

      <FeatureRow
        eyebrow="Private by default"
        title="Import a statement, let AI sort it"
        name="import"
        alt="Import review screen with AI-categorized transactions"
        bullets={['PDF, CSV & Excel — even several at once', 'Runs on your Mac, or falls back to your own ChatGPT', 'Review, fix, and teach it rules as you go']}
      >
        Export a PDF, CSV, or Excel file from your bank and drop it in. The AI
        categorizes every transaction by purpose — and it runs on your Mac. No
        bank connection, and your statements aren’t sent to our servers.
      </FeatureRow>

      <div class="frow frow--flip">
        <div class="frow__copy">
          <p class="eyebrow">Every krone accounted for</p>
          <h3 class="frow__title">All your accounts, one clean list</h3>
          <p class="frow__body text-muted">
            Filter, sort, re-categorize in bulk, add notes, and build rules that
            stick. Transfers between your own accounts pair up automatically, so a
            move from checking to savings never double-counts as spending.
          </p>
          <ul class="frow__list">
            <li>Multi-account, one searchable view</li>
            <li>Keyword &amp; natural-language rules</li>
            <li>Export anything to CSV</li>
          </ul>
        </div>
        <div class="frow__media">
          <div class="shot-stack">
            <figure class="shot shot-stack__back">
              <div class="shot__body">
                <img
                  src={`${base}/screenshots/${defaultTheme}/transactions.png`}
                  data-shot="transactions"
                  alt="Transactions list with categories and amounts across accounts"
                  loading="lazy"
                />
              </div>
            </figure>
            <figure class="shot shot-stack__front">
              <div class="shot__body">
                <img
                  src={`${base}/screenshots/${defaultTheme}/transactions-match.png`}
                  data-shot="transactions-match"
                  alt="Auto-matched transfer pairing two accounts into one internal transfer"
                  loading="lazy"
                  onerror="this.closest('.shot-stack__front').style.display='none';"
                />
              </div>
            </figure>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondary points -->
  <section class="section section--subtle">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Why it’s different</p>
        <h2>Calm, private, and free.</h2>
      </div>
      <div class="feature-grid">
        {secondary.map((f) => <Feature icon={f.icon} title={f.title}>{f.body}</Feature>)}
      </div>
    </div>
  </section>

  <!-- Themes showcase -->
  <section class="section themes">
    <div class="container center">
      <p class="eyebrow">Make it yours</p>
      <h2>Themes that feel right at home.</h2>
      <p class="lead themes__lead">
        Allocate ships with Rosé Pine Dawn and a set of beloved editor themes —
        Nord, Catppuccin, Tokyo Night and more. Tap one to preview it right here.
      </p>
      <div class="themes__grid">
        {
          themes.map((t) => (
            <button type="button" class="themecard" data-set-theme={t.id} style={`--c-bg:${t.bg};--c-accent:${t.accent};--c-text:${t.text}`}>
              <span class="themecard__swatch">
                <span class="themecard__line themecard__line--lg" />
                <span class="themecard__line" />
                <span class="themecard__pill" />
              </span>
              <span class="themecard__name">{t.name}</span>
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="section section--subtle">
    <div class="container">
      <div class="center">
        <p class="eyebrow">How it works</p>
        <h2>Set it up once. Then a few minutes a month.</h2>
        <p class="lead">No dashboards to babysit. A little planning up front, then a calm monthly rhythm.</p>
      </div>

      <div class="phase">
        <div class="phase__label">
          <span class="phase__tag">Set up once</span>
          <p class="text-muted">Decide what “paying yourself first” looks like for you.</p>
        </div>
        <ol class="steps steps--2">
          {
            setupSteps.map((s) => (
              <li class="step">
                <span class="step__n" aria-hidden="true">{s.n}</span>
                <h3>{s.title}</h3>
                <p class="text-muted">{s.body}</p>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="phase">
        <div class="phase__label">
          <span class="phase__tag">Then, once a month</span>
          <p class="text-muted">The whole routine takes minutes — adjust for the long run and move on.</p>
        </div>
        <ol class="steps steps--4">
          {
            monthlySteps.map((s) => (
              <li class="step">
                <span class="step__n" aria-hidden="true">{s.n}</span>
                <h3>{s.title}</h3>
                <p class="text-muted">{s.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section id="privacy" class="section">
    <div class="container privacy">
      <div>
        <p class="eyebrow">Privacy by design</p>
        <h2>Your finances never leave your control.</h2>
        <p class="text-muted">
          Allocate has no custom backend and requires no account. Transactions are
          stored on your device with SwiftData and synced only through your own
          iCloud. Even the AI categorization runs on your Mac — or, if you prefer,
          through your own ChatGPT account. There’s nothing for us to see, sell, or
          lose.
        </p>
        <ul class="privacy__list">
          <li>No sign-up, no email required to use the app</li>
          <li>Data stored on-device and in your private iCloud</li>
          <li>AI runs locally, or via your own ChatGPT — never our servers</li>
          <li>Export everything to CSV whenever you want</li>
        </ul>
        <p><a href={`${base}/privacy`}>Read the full privacy policy →</a></p>
      </div>
      <div class="privacy__badge" aria-hidden="true">
        <span set:html={icons.lock} />
        <strong>On-device first</strong>
        <span class="text-muted">No backend. No tracking of your money.</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--tight cta">
    <div class="container center">
      <h2>Start paying yourself first.</h2>
      <p class="lead">Allocate is coming to macOS. Be the first to know when it ships.</p>
      <div class="hero__cta center-cta">
        <Button href="/download">Get Allocate</Button>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ base, defaultTheme }}>
    (function () {
      function currentTheme() {
        var t = document.documentElement.getAttribute('data-theme');
        if (t) return t;
        try { return localStorage.getItem('allocate-theme') || defaultTheme; } catch (e) {}
        return defaultTheme;
      }
      function applyMedia(theme) {
        // Feature-row screenshots
        document.querySelectorAll('img[data-shot]').forEach(function (img) {
          var name = img.getAttribute('data-shot');
          img.style.display = '';
          // restore a stacked overlay figure that a previous theme may have hidden
          var front = img.closest('.shot-stack__front');
          if (front) front.style.display = '';
          img.src = base + '/screenshots/' + theme + '/' + name + '.png';
        });
        // Hero demo video
        var v = document.querySelector('video[data-demo]');
        if (v) {
          v.setAttribute('poster', base + '/screenshots/' + theme + '/home.png');
          v.querySelectorAll('source[data-demo-src]').forEach(function (s) {
            var kind = s.getAttribute('data-demo-src');
            s.src = base + '/demo-' + theme + '.' + kind;
          });
          v.load();
          var p = v.play();
          if (p && p.catch) p.catch(function () {});
        }
      }
      // Swap when any theme control is clicked (Header arrays removed; the
      // theme cards on this page are the source of truth).
      document.querySelectorAll('[data-set-theme]').forEach(function (b) {
        b.addEventListener('click', function () {
          applyMedia(b.getAttribute('data-set-theme'));
        });
      });
      // Initial sync (in case a non-default theme was restored from storage).
      var t = currentTheme();
      if (t !== defaultTheme) applyMedia(t);
    })();
  </script>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-5xl) var(--space-4xl);
    overflow: hidden;
    background:
      radial-gradient(
        120% 90% at 85% -10%,
        color-mix(in srgb, var(--accent) 18%, transparent),
        transparent 55%
      );
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  .hero__copy h1 {
    margin-bottom: var(--space-l);
  }
  .hero__cta {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }
  .hero__note {
    margin-top: var(--space-l);
    font-size: 0.92rem;
  }
  /* Hero screenshot bleeds toward the right edge */
  .hero__media {
    margin-right: calc(-1 * var(--space-4xl));
  }

  /* Clean rounded screenshot / video panel (shared shape with FeatureRow) */
  .shot {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-window);
  }
  .shot__body {
    background: var(--bg);
  }
  .shot__body img {
    display: block;
    width: 100%;
    height: auto;
  }
  .shot__body video {
    display: block;
    width: 100%;
    height: auto;
  }
  .shot__ph {
    aspect-ratio: 16 / 10;
    place-content: center;
    justify-items: center;
    gap: var(--space-m);
    color: var(--text-faint);
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 14px,
      color-mix(in srgb, var(--text-faint) 6%, transparent) 14px,
      color-mix(in srgb, var(--text-faint) 6%, transparent) 28px
    );
  }
  .shot__ph svg { width: 56px; height: 56px; opacity: 0.7; }
  .shot__ph span { font-size: 0.95rem; font-weight: 500; }
  .shot--hero .shot__ph { aspect-ratio: 16 / 9; }

  /* Pay Yourself First — themed stat panel (re-themes live, no screenshot) */
  .pyf {
    display: grid;
    gap: var(--space-l);
    padding: var(--space-2xl);
    background: var(--bg-elevated);
  }
  .pyf__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }
  .pyf__eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .pyf__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-pill);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--success);
    background: color-mix(in srgb, var(--success) 16%, transparent);
  }
  .pyf__pill::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--success);
  }
  .pyf__rate {
    display: grid;
    gap: var(--space-xs);
  }
  .pyf__rate strong {
    font-size: clamp(3.2rem, 7vw, 4.6rem);
    line-height: 0.95;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .pyf__rate strong span {
    font-size: 0.45em;
    color: var(--accent-strong);
    margin-left: 0.1em;
  }
  .pyf__rate-label {
    color: var(--text-muted);
    font-size: 0.98rem;
    max-width: 30ch;
  }
  .pyf__bar {
    position: relative;
    height: 12px;
    border-radius: var(--radius-pill);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    margin-top: var(--space-xs);
  }
  .pyf__bar-fill {
    position: absolute;
    inset: 0 auto 0 0;
    border-radius: var(--radius-pill);
    background: linear-gradient(90deg, var(--accent), var(--accent-strong));
  }
  .pyf__bar-target {
    position: absolute;
    top: -1.7rem;
    transform: translateX(-50%);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-faint);
    white-space: nowrap;
  }
  .pyf__bar-target i {
    position: absolute;
    top: 1.35rem;
    left: 50%;
    width: 2px;
    height: 18px;
    background: var(--text-faint);
    opacity: 0.6;
  }
  .pyf__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-m);
    margin-top: var(--space-s);
  }
  .pyf__stat {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    column-gap: 0.5rem;
    padding: var(--space-m);
    border-radius: var(--radius-card);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
  }
  .pyf__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }
  .pyf__dot--saved { background: var(--success); }
  .pyf__dot--invested { background: var(--success-light); }
  .pyf__stat-k {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .pyf__stat b {
    grid-column: 2;
    font-size: 1.15rem;
    color: var(--text);
  }
  .pyf__foot {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-faint);
  }
  .pyf__foot b { color: var(--text-muted); }

  /* Stacked screenshots (Transactions) */
  .shot-stack {
    position: relative;
    padding-bottom: 64px;
    padding-right: 28px;
  }
  .shot-stack__back {
    margin: 0;
  }
  .shot-stack__front {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 62%;
    margin: 0;
    box-shadow: var(--shadow-window);
  }
  @media (max-width: 880px) {
    .shot-stack {
      padding-bottom: 48px;
      padding-right: 0;
    }
    .shot-stack__front { width: 72%; }
  }

  /* Intro band */
  .intro {
    padding-top: var(--space-2xl);
  }
  .intro__headline {
    max-width: 18ch;
    margin-inline: auto;
  }
  .intro__lead {
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }
  .intro__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-s);
  }
  .intro__chips li {
    padding: 0.4rem 0.95rem;
    border-radius: var(--radius-pill);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Feature rows */
  .feature-rows {
    display: grid;
