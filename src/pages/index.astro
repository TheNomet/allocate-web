---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Feature from '../components/Feature.astro';
import FeatureRow from '../components/FeatureRow.astro';
import { icons } from '../components/icons';
import { SITE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const secondary = [
  {
    icon: icons.calendar,
    title: 'Calm',
    body: 'Check in once a month — no real-time pings, no daily guilt. See where you landed, adjust, and get on with your life.',
  },
  {
    icon: icons.lock,
    title: 'Private',
    body: 'No account, no backend. Everything stays on your Mac and your own iCloud. There’s nothing for anyone to sell or leak.',
  },
  {
    icon: icons.tag,
    title: 'Free',
    body: 'No subscription, no paid bank connectors. You shouldn’t have to pay money just to manage your money.',
  },
];

const setupSteps = [
  {
    n: '1',
    title: 'Set your goal',
    body: 'Decide how much to pay yourself each month — the amount you’ll save and invest before spending on anything else.',
  },
  {
    n: '2',
    title: 'Build your budgets',
    body: 'Turn that goal into budgets for the rest. Allocate suggests budgets from your past spending, so the targets are grounded in reality, not wishful thinking.',
  },
];

const monthlySteps = [
  {
    n: '1',
    title: 'Import your statement',
    body: 'Export a PDF, CSV, or Excel file from your bank and drop it into Allocate. No bank connection, no extra fees.',
  },
  {
    n: '2',
    title: 'Let the AI sort it',
    body: 'Every transaction is categorized automatically. Skim it, fix the few it wasn’t sure about, and you’re done in minutes.',
  },
  {
    n: '3',
    title: 'See where you landed',
    body: 'Did you pay yourself first? Are you over or under budget? Allocate shows you clearly — you decide what it means.',
  },
  {
    n: '4',
    title: 'Adjust, then live',
    body: 'Nudge next month’s plan to keep a good average over the long run. Then close the laptop and get on with your life.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow">macOS personal finance</p>
        <h1>Pay yourself<br />first.</h1>
        <p class="lead">
          Allocate turns a bank statement into a clear picture of what you earned,
          what you kept, and whether you’re on track — automatically, and entirely
          on your Mac.
        </p>
        <div class="hero__cta">
          <Button href="/download">Get Allocate</Button>
          <Button href="/#how" variant="secondary">See how it works</Button>
        </div>
        <p class="hero__note text-muted">
          {SITE.requirements} · No account · Free
        </p>
      </div>
      <div class="hero__media">
        <div class="window">
          <div class="window__bar">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          </div>
          <picture>
            <source srcset={`${base}/screenshots/hero-dark.png`} media="(prefers-color-scheme: dark)" />
            <img src={`${base}/screenshots/hero-light.png`} alt="Allocate dashboard showing a 30% pay-yourself-first rate and spending overview" width="1100" height="538" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature rows -->
  <section id="features" class="section">
    <div class="container feature-rows">
      <FeatureRow
        eyebrow="The headline number"
        title="Pay yourself first"
        image="pyf"
        alt="Pay Yourself First card showing a 30% rate, saved and invested amounts"
      >
        Decide what you set aside before anything else — like a salary you owe your
        future self. Allocate shows the one number that matters: how much of your
        income you actually kept, saved and invested.
      </FeatureRow>

      <FeatureRow
        eyebrow="Goals → budgets"
        title="Budgets grounded in reality"
        image="budget"
        alt="Budget Progress card with fixed, variable, savings and investment rows"
        flip
      >
        Pick how much to save and invest, then let the rest become budgets.
        Allocate suggests them from your own past spending, so your targets are
        realistic — and you can see, at a glance, where you’re over or under.
      </FeatureRow>

      <FeatureRow
        eyebrow="See it clearly"
        title="Where your money actually goes"
        image="spending"
        alt="Spending Overview donut chart broken down by category"
      >
        A clean breakdown of spending by category — no spreadsheet wrangling. The
        AI categorizes every transaction by purpose, so refunds and transfers land
        in the right place and the totals tell the truth.
      </FeatureRow>

      <FeatureRow
        eyebrow="The long run"
        title="One month doesn’t define you"
        image="trend"
        alt="Income versus spending chart across recent months"
        flip
      >
        Income against spending, month over month. A great month or a rough one is
        just one data point — watch the trend and adjust next month to keep a
        healthy average over time.
      </FeatureRow>
    </div>
  </section>

  <!-- Secondary points -->
  <section class="section section--subtle">
    <div class="container">
      <div class="center">
        <p class="eyebrow">Why it’s different</p>
        <h2>Calm, private, and free.</h2>
      </div>
      <div class="feature-grid">
        {secondary.map((f) => <Feature icon={f.icon} title={f.title}>{f.body}</Feature>)}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how" class="section">
    <div class="container">
      <div class="center">
        <p class="eyebrow">How it works</p>
        <h2>Set it up once. Then a few minutes a month.</h2>
        <p class="lead">No dashboards to babysit. A little planning up front, then a calm monthly rhythm.</p>
      </div>

      <div class="phase">
        <div class="phase__label">
          <span class="phase__tag">Set up once</span>
          <p class="text-muted">Decide what “paying yourself first” looks like for you.</p>
        </div>
        <ol class="steps steps--2">
          {
            setupSteps.map((s) => (
              <li class="step">
                <span class="step__n" aria-hidden="true">{s.n}</span>
                <h3>{s.title}</h3>
                <p class="text-muted">{s.body}</p>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="phase">
        <div class="phase__label">
          <span class="phase__tag">Then, once a month</span>
          <p class="text-muted">The whole routine takes minutes — adjust for the long run and move on.</p>
        </div>
        <ol class="steps steps--4">
          {
            monthlySteps.map((s) => (
              <li class="step">
                <span class="step__n" aria-hidden="true">{s.n}</span>
                <h3>{s.title}</h3>
                <p class="text-muted">{s.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section id="privacy" class="section section--subtle">
    <div class="container privacy">
      <div>
        <p class="eyebrow">Privacy by design</p>
        <h2>Your finances never leave your control.</h2>
        <p class="text-muted">
          Allocate has no custom backend and requires no account. Transactions
          are stored on your device with SwiftData and synced only through your
          own iCloud. There's nothing for us to see, sell, or lose.
        </p>
        <ul class="privacy__list">
          <li>No sign-up, no email required to use the app</li>
          <li>Data stored on-device and in your private iCloud</li>
          <li>Export everything to CSV whenever you want</li>
        </ul>
        <p><a href={`${base}/privacy`}>Read the full privacy policy →</a></p>
      </div>
      <div class="privacy__badge" aria-hidden="true">
        <span set:html={icons.lock} />
        <strong>On-device first</strong>
        <span class="text-muted">No backend. No tracking of your money.</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--tight cta">
    <div class="container center">
      <h2>Start paying yourself first.</h2>
      <p class="lead">Allocate is coming to macOS. Be the first to know when it ships.</p>
      <div class="hero__cta center-cta">
        <Button href="/download">Get Allocate</Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-block: var(--space-5xl) var(--space-4xl);
    overflow: hidden;
    background:
      radial-gradient(
        120% 90% at 85% -10%,
        color-mix(in srgb, var(--accent) 16%, transparent),
        transparent 55%
      );
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .hero__copy h1 {
    margin-bottom: var(--space-l);
  }
  .hero__cta {
    display: flex;
    gap: var(--space-m);
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }
  .hero__note {
    margin-top: var(--space-l);
    font-size: 0.92rem;
  }
  /* Hero screenshot bleeds toward the right edge */
  .hero__media {
    margin-right: calc(-1 * var(--space-3xl));
  }

  /* macOS window frame */
  .window {
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-window);
  }
  .window__bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    height: 36px;
    padding: 0 var(--space-l);
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .window__bar .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--border);
  }
  .window__bar .dot:nth-child(1) {
    background: #ff5f57;
  }
  .window__bar .dot:nth-child(2) {
    background: #febc2e;
  }
  .window__bar .dot:nth-child(3) {
    background: #28c840;
  }
  .window img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Feature rows */
  .feature-rows {
    display: grid;
    gap: var(--space-5xl);
  }

  /* Secondary feature grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    margin-top: var(--space-3xl);
  }

  /* Privacy */
  .privacy {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .privacy__list {
    margin: var(--space-l) 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-s);
  }
  .privacy__list li {
    position: relative;
    padding-left: 1.8rem;
    color: var(--text-muted);
  }
  .privacy__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 12px;
    height: 7px;
    border-left: 2.4px solid var(--success);
    border-bottom: 2.4px solid var(--success);
    transform: rotate(-45deg);
  }
  .privacy__badge {
    display: grid;
    justify-items: center;
    gap: var(--space-s);
    text-align: center;
    padding: var(--space-3xl);
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
  }
  .privacy__badge :global(svg) {
    width: 48px;
    height: 48px;
    color: var(--accent-strong);
  }
  .privacy__badge strong {
    font-size: 1.2rem;
  }

  /* Steps */
  .phase {
    margin-top: var(--space-3xl);
  }
  .phase__label {
    margin-bottom: var(--space-l);
  }
  .phase__label p {
    margin: var(--space-s) 0 0;
  }
  .phase__tag {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-l);
    margin: 0;
    padding: 0;
  }
  .steps--2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .steps--4 {
    grid-template-columns: repeat(4, 1fr);
  }
  .step {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: var(--space-xl);
    box-shadow: var(--shadow-card);
  }
  .step__n {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 800;
    margin-bottom: var(--space-l);
  }
  .step h3 {
    margin-bottom: var(--space-s);
  }
  .step p {
    margin: 0;
  }

  /* CTA */
  .cta {
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }
  .center-cta {
    justify-content: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 880px) {
    .hero__inner,
    .privacy {
      grid-template-columns: 1fr;
    }
    .hero__media {
      order: -1;
      margin-right: 0;
    }
    .feature-grid {
      grid-template-columns: 1fr;
    }
    .feature-rows {
      gap: var(--space-4xl);
    }
    .steps,
    .steps--2 {
      grid-template-columns: 1fr;
    }
    .steps--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .feature-grid,
    .steps--4 {
      grid-template-columns: 1fr;
    }
  }
</style>
