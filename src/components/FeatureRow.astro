---
// Alternating image + text feature row. Pass an image base name
// (e.g. "pyf") and the component renders /screenshots/{base}-light.png
// and /screenshots/{base}-dark.png via <picture> for theme support.
interface Props {
  eyebrow?: string;
  title: string;
  image: string;
  alt: string;
  flip?: boolean;
}
const { eyebrow, title, image, alt, flip = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class:list={['frow', { 'frow--flip': flip }]}>
  <div class="frow__copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h3 class="frow__title">{title}</h3>
    <p class="text-muted"><slot /></p>
  </div>
  <div class="frow__media">
    <picture>
      <source srcset={`${base}/screenshots/${image}-dark.png`} media="(prefers-color-scheme: dark)" />
      <img src={`${base}/screenshots/${image}-light.png`} alt={alt} loading="lazy" />
    </picture>
  </div>
</div>

<style>
  .frow {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  .frow--flip .frow__copy {
    order: 2;
  }
  .frow__title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: var(--space-m);
  }
  .frow__copy p {
    font-size: 1.1rem;
    margin: 0;
    max-width: 42ch;
  }
  .frow__media {
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-window);
    padding: var(--space-l);
    overflow: hidden;
  }
  .frow__media img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    display: block;
  }
  @media (max-width: 820px) {
    .frow {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .frow--flip .frow__copy {
      order: 0;
    }
  }
</style>
