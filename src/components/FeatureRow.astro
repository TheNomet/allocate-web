---
// Alternating image + text feature row, framed as a clean rounded panel.
//
// Pass a screenshot base `name` (without extension). The image resolves to
// /public/screenshots/<defaultTheme>/<name>.png and carries a data-shot hook
// so the theme switcher can swap it to another theme's capture live.
interface Props {
  eyebrow?: string;
  title: string;
  name: string; // e.g. "net-worth"
  alt: string;
  flip?: boolean;
  bullets?: string[];
}
const {
  eyebrow,
  title,
  name,
  alt,
  flip = false,
  bullets = [],
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const DEFAULT_THEME = 'rosepine-dawn';
const resolved = `${base}/screenshots/${DEFAULT_THEME}/${name}.png`;
---

<div class:list={['frow', { 'frow--flip': flip }]}>
  <div class="frow__copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h3 class="frow__title">{title}</h3>
    <p class="frow__body text-muted"><slot /></p>
    {
      bullets.length > 0 && (
        <ul class="frow__list">
          {bullets.map((b) => (
            <li>{b}</li>
          ))}
        </ul>
      )
    }
  </div>
  <div class="frow__media">
    <figure class="shot">
      <div class="shot__body">
        <img
          src={resolved}
          data-shot={name}
          alt={alt}
          loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='grid';"
        />
        <div class="shot__ph" style="display:none" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <rect x="3" y="4" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/>
            <path d="M3 14l4-4 4 4 3-3 7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8.5" cy="9" r="1.5" fill="currentColor"/>
          </svg>
          <span>Screenshot coming soon</span>
        </div>
      </div>
    </figure>
  </div>
</div>

<style>
  .frow {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  .frow--flip .frow__copy {
    order: 2;
  }
  .frow__title {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    margin-bottom: var(--space-m);
  }
  .frow__body {
    font-size: 1.12rem;
    margin: 0;
    max-width: 44ch;
  }
  .frow__list {
    list-style: none;
    margin: var(--space-l) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-s);
    max-width: 44ch;
  }
  .frow__list li {
    position: relative;
    padding-left: 1.7rem;
    color: var(--text-muted);
    font-size: 1rem;
  }
  .frow__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45rem;
    width: 11px;
    height: 7px;
    border-left: 2.4px solid var(--accent-strong);
    border-bottom: 2.4px solid var(--accent-strong);
    transform: rotate(-45deg);
  }

  /* Clean rounded screenshot panel */
  .shot {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-window);
  }
  .shot__body {
    background: var(--bg);
  }
  .shot__body img {
    display: block;
    width: 100%;
    height: auto;
  }
  .shot__ph {
    aspect-ratio: 16 / 10;
    place-content: center;
    justify-items: center;
    gap: var(--space-m);
    color: var(--text-faint);
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 14px,
      color-mix(in srgb, var(--text-faint) 6%, transparent) 14px,
      color-mix(in srgb, var(--text-faint) 6%, transparent) 28px
    );
  }
  .shot__ph svg {
    width: 52px;
    height: 52px;
    opacity: 0.7;
  }
  .shot__ph span {
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 880px) {
    .frow {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .frow--flip .frow__copy {
      order: 0;
    }
  }
</style>
</content>
</invoke>
