---
import { SITE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: '/#features', label: 'Features' },
  { href: '/#how', label: 'How it works' },
  { href: '/#privacy', label: 'Privacy' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={`${base}/`} class="brand" aria-label={`${SITE.name} home`}>
      <img class="brand__mark" src={`${base}/brand/logo-symbol.png`} width="30" height="30" alt="" />
      <span class="brand__name">{SITE.name}</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={`${base}${l.href}`}>{l.label}</a>)}
      <a class="nav__cta" href={`${base}/download`}>Get Allocate</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    color: var(--text);
    font-weight: 700;
    font-size: 1.1rem;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand__mark {
    display: block;
    width: 30px;
    height: 30px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }
  .nav a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .nav__cta {
    padding: 0.45rem 1rem;
    border-radius: var(--radius-pill);
    background: var(--accent);
    color: var(--on-accent) !important;
    font-weight: 600;
  }
  .nav__cta:hover {
    background: var(--accent-strong);
  }
  @media (max-width: 640px) {
    .nav {
      gap: var(--space-m);
    }
    .nav a:not(.nav__cta) {
      display: none;
    }
  }
</style>
