---
// A macOS-style window frame. Pass `src` once real screenshots exist
// (export from designs/allocalte.pen into public/screenshots/);
// until then a labelled placeholder is shown so layout is final.
interface Props {
  title?: string;
  src?: string;
  alt?: string;
  label?: string;
  ratio?: string; // width/height, e.g. "1100/720"
}
const {
  title = 'Allocate',
  src,
  alt = '',
  label = 'Screenshot coming soon',
  ratio = '1100 / 720',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolved = src ? (src.startsWith('/') ? `${base}${src}` : src) : undefined;
---

<figure class="window">
  <div class="window__bar">
    <span class="dot dot--red" aria-hidden="true"></span>
    <span class="dot dot--amber" aria-hidden="true"></span>
    <span class="dot dot--green" aria-hidden="true"></span>
    <span class="window__title">{title}</span>
  </div>
  <div class="window__body" style={`aspect-ratio: ${ratio};`}>
    {
      resolved ? (
        <img src={resolved} alt={alt} loading="lazy" />
      ) : (
        <div class="placeholder">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="4" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6" />
            <path d="M3 14l4-4 4 4 3-3 7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="8.5" cy="9" r="1.5" fill="currentColor" />
          </svg>
          <span>{label}</span>
        </div>
      )
    }
  </div>
</figure>

<style>
  .window {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-window);
  }
  .window__bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    padding: 0 var(--space-l);
    height: 38px;
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot--red {
    background: #ff5f57;
  }
  .dot--amber {
    background: #febc2e;
  }
  .dot--green {
    background: #28c840;
  }
  .window__title {
    margin-left: auto;
    margin-right: auto;
    font-size: 0.82rem;
    color: var(--text-faint);
    transform: translateX(-18px);
  }
  .window__body {
    width: 100%;
    background: var(--bg);
  }
  .window__body img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: var(--space-m);
    color: var(--text-faint);
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 14px,
        color-mix(in srgb, var(--text-faint) 6%, transparent) 14px,
        color-mix(in srgb, var(--text-faint) 6%, transparent) 28px
      );
  }
  .placeholder svg {
    width: 56px;
    height: 56px;
    opacity: 0.7;
  }
  .placeholder span {
    font-size: 0.95rem;
    font-weight: 500;
  }
</style>
